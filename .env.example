# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# OnCallDev / TeleClaw (optional)
# -----------------------------------------------------------------------------
# ONCALLDEV_ENABLED=1
# TELECLAW_DATA_DIR=~/.openclaw/teleclaw
# TELECLAW_PROJECTS_STORE_PATH=~/.openclaw/teleclaw/projects.json
# TELECLAW_SESSIONS_STORE_PATH=~/.openclaw/teleclaw/sessions.json
# TELECLAW_MEMORY_STORE_PATH=~/.openclaw/teleclaw/memory.json
# TELECLAW_VOICE_STORE_PATH=~/.openclaw/teleclaw/voice
# PROJECTS_ROOT=/workspace
# ALLOWED_PROJECT_MOUNTS=/workspace,/srv/teleclaw-projects
# CONTAINER_RUNTIME=local
# TELECLAW_RUNTIME_STORE_PATH=~/.openclaw/teleclaw/runtime.json
# TELECLAW_DOCKER_ENABLED=0
# TELECLAW_DOCKER_NETWORK=bridge
# TELECLAW_DOCKER_IMAGE_PYTHON=python:3.12-slim
# TELECLAW_DOCKER_IMAGE_NODE=node:22-bookworm-slim
# TELECLAW_DOCKER_IMAGE_GENERIC=ubuntu:24.04
# TELECLAW_RUNTIME_BOOTSTRAP_ENABLED=1
# TELECLAW_GIT_ENABLED=1
# TELECLAW_BOOTSTRAP_DEFAULT_RUNTIME=generic
# TELECLAW_DEFAULT_PYTHON_INSTALL_COMMAND=uv sync
# TELECLAW_DEFAULT_PYTHON_TEST_COMMAND=pytest
# TELECLAW_DEFAULT_NODE_INSTALL_COMMAND=npm install
# TELECLAW_DEFAULT_NODE_TEST_COMMAND=npm test
# OPENHANDS_ENABLED=1
# OPENHANDS_MODE=vendor_local
# OPENHANDS_VENDOR_PATH=vendor/openhands
# OPENHANDS_PYTHON_BIN=python3
# OPENHANDS_LOG_LEVEL=INFO
# OPENHANDS_ENDPOINT=http://localhost:3001
# ONCALLDEV_OPENHANDS_API_KEY=
# STT_PROVIDER=whisper.cpp
# STT_MODEL=
# STT_LANGUAGE=
# STT_WHISPERCPP_BIN=whisper-cli
# STT_WHISPERCPP_MODEL=./models/ggml-base.en.bin
# STT_WHISPERCPP_LANGUAGE=
# STT_WHISPERCPP_THREADS=4
# STT_MIN_CONFIDENCE=0.35
# STT_PROVIDER_TIMEOUT_MS=60000
# STT_API_KEY=
# TTS_PROVIDER=piper
# TTS_API_KEY=
# TTS_BASE_URL=https://api.openai.com/v1
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy
# TTS_PIPER_BIN=piper
# TTS_PIPER_MODEL=./models/en_US-lessac-medium.onnx
# TTS_PIPER_VOICE=
# TTS_FORMAT=wav
# TTS_OUTPUT_DIR=~/.openclaw/teleclaw/voice
# TTS_OUTPUT_TTL_SECONDS=604800
# TTS_OUTPUT_MAX_FILES=500
# TTS_PROVIDER_TIMEOUT_MS=30000
# TELECLAW_RUN_REAL_STT_TESTS=0
# TELECLAW_RUN_REAL_TTS_TESTS=0
# ENABLE_VOICE_REPLIES=0
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-5.4
# DEFAULT_REPLY_MODE=text
